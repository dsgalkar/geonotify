# ─────────────────────────────────────────────────────────────
# NagarDrishti — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to git.
# ─────────────────────────────────────────────────────────────

# Google Maps API Key
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Maps SDK for Android, Maps SDK for iOS, Geocoding API
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Backend API Base URL
# For local development: http://10.0.2.2:8000/api/v1  (Android emulator)
# For production:        https://api.nagardrishti.gov.in/v1
API_BASE_URL=http://10.0.2.2:8000/api/v1

# Firebase
# Run: flutterfire configure — it generates google-services.json automatically
# These are for reference only; actual config lives in google-services.json
FIREBASE_PROJECT_ID=nagardrishti-hackathon
FIREBASE_APP_ID=1:000000000000:android:abcdef1234567890

# Feature Flags (set to "true" / "false")
ENABLE_MOCK_DATA=true          # Use sampleProjects when backend is unavailable
ENABLE_ANALYTICS=false         # Disable during hackathon demo
ENABLE_CRASH_REPORTING=false
